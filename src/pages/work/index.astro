---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const work = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Work" description="Selected product and design work by Farrukh Jamal.">
  <section class="page container">
    <p class="kicker"><span>Work</span></p>
    <ul class="list">
      {work.map((w) => (
        <li>
          <a class="row" href={`/work/${w.id}`}>
            <h2>{w.data.title}<span class="arrow" aria-hidden="true">→</span></h2>
            <p class="meta">{w.data.company} <span class="dot">·</span> {w.data.product} <span class="dot">·</span> {w.data.role} <span class="dot">·</span> {w.data.years}</p>
            <p class="problem">{w.data.problem}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: var(--s-9);
    padding-bottom: var(--s-9);
  }
  .kicker {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin: 0 0 var(--s-8);
  }
  .kicker span { white-space: nowrap; }
  .kicker::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 320px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .list li { max-width: var(--w-text); }
  .row {
    display: block;
    padding: var(--s-5);
    margin: 0 calc(-1 * var(--s-5));
    border: 1px solid transparent;
    border-radius: 2px;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    border-bottom: none;
  }
  .row:hover,
  .row:focus-visible {
    background-color: var(--bg-elevated);
    border-color: var(--border);
  }
  .row h2 {
    font-size: var(--size-h2);
    margin: 0 0 var(--s-3);
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    transition: color 0.15s ease;
  }
  .row:hover h2,
  .row:focus-visible h2 { color: var(--ink-bright); }
  .arrow {
    font-family: var(--font-mono);
    font-size: var(--size-ui);
    color: var(--ink-bright);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    display: inline-block;
  }
  .row:hover .arrow,
  .row:focus-visible .arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .meta {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--muted);
    margin: 0 0 var(--s-3);
    font-feature-settings: 'ss01', 'ss02';
  }
  .dot { color: var(--border); padding: 0 var(--s-1); }
  .problem {
    font-size: var(--size-body);
    color: var(--ink);
    margin: 0;
    line-height: var(--lh-body);
  }
</style>
