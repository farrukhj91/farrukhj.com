---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Writing" description="Essays and notes." noindex={true}>
  <section class="page container">
    <h1>Writing</h1>
    {posts.length === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      <ul class="list">
        {posts.map((p) => (
          <li>
            <h2><a href={`/writing/${p.id}`}>{p.data.title}</a></h2>
            <p class="meta">{p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            <p>{p.data.summary}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page { padding-top: var(--s-9); padding-bottom: var(--s-9); }
  .page > h1 { margin-bottom: var(--s-8); }
  .empty { margin-top: var(--s-7); color: var(--muted); }
  .list { margin-top: var(--s-7); }
  .list li { margin-bottom: var(--s-7); }
  .list h2 { font-size: var(--size-h2); margin: 0; }
  .list h2 a { border-bottom: none; color: var(--ink); }
  .list h2 a:hover, .list h2 a:focus-visible { color: var(--ink-bright); }
  .meta {
    font-size: var(--size-meta);
    color: var(--muted);
    margin: var(--s-2) 0 0;
    letter-spacing: 0.01em;
  }
</style>
