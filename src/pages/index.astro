---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeBackground from '../components/HomeBackground.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const featured = all.filter((w) => w.data.featured);
const hasMore = all.length > featured.length;
---
<BaseLayout description="Farrukh Jamal — Senior Product Manager with a design-led background, currently building AI-native product.">
  <HomeBackground />
  <section class="home container">
    <header class="opener">
      <h1 class="wordmark">Farrukh Jamal</h1>
      <p class="positioning">Product manager with a design-led background. Eight years in, currently building AI-native product at <a href="https://leadpursuits.com">Lead Pursuits</a>.</p>
    </header>

    {featured.length > 0 && (
      <section class="work-list" aria-label="Work">
        <ul>
          {featured.map((w) => (
            <li>
              <a class="row" href={`/work/${w.id}`}>
                <h2>{w.data.title}<span class="arrow" aria-hidden="true">→</span></h2>
                <p class="meta">{w.data.company} <span class="dot">·</span> {w.data.product} <span class="dot">·</span> {w.data.role} <span class="dot">·</span> {w.data.years}</p>
                <p class="problem">{w.data.problem}</p>
              </a>
            </li>
          ))}
        </ul>

        {hasMore && (
          <a href="/work" class="see-all">All work <span aria-hidden="true">→</span></a>
        )}
      </section>
    )}
  </section>
</BaseLayout>

<style>
  .home {
    padding-top: var(--s-10);
    padding-bottom: var(--s-9);
    position: relative;
    z-index: 1;
  }
  .opener {
    margin-bottom: var(--s-8);
    max-width: var(--w-text);
  }
  .wordmark {
    font-size: var(--size-h1);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: var(--lh-h1);
    color: var(--ink-bright);
    margin-bottom: var(--s-5);
  }
  .positioning {
    font-size: 17px;
    color: var(--ink);
    line-height: 1.55;
    margin: 0;
    max-width: 56ch;
  }
  .positioning a {
    color: var(--ink-bright);
    border-bottom: 1px solid var(--border);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .positioning a:hover,
  .positioning a:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .work-list {
    max-width: var(--w-page);
    border-top: 1px solid var(--border);
    padding-top: var(--s-7);
  }
  .work-list ul {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .work-list li { max-width: var(--w-text); }
  .row {
    display: block;
    padding: var(--s-5);
    margin: 0 calc(-1 * var(--s-5));
    border: 1px solid transparent;
    border-radius: 2px;
    transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    border-bottom: none;
  }
  .row:hover,
  .row:focus-visible {
    background-color: var(--bg-elevated);
    border-color: var(--border);
    transform: translateY(-1px);
    box-shadow: 0 0 24px -8px var(--accent-glow);
  }
  @media (prefers-reduced-motion: reduce) {
    .row { transition: background-color 0.15s ease, border-color 0.15s ease; }
    .row:hover, .row:focus-visible { transform: none; }
  }
  .row h2 {
    font-size: var(--size-h2);
    margin: 0 0 var(--s-3);
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    transition: color 0.15s ease;
  }
  .row:hover h2,
  .row:focus-visible h2 { color: var(--ink-bright); }
  .arrow {
    font-family: var(--font-mono);
    font-size: var(--size-ui);
    color: var(--accent);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    display: inline-block;
  }
  .row:hover .arrow,
  .row:focus-visible .arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .meta {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--muted);
    margin: 0 0 var(--s-3);
    font-feature-settings: 'ss01', 'ss02';
  }
  .dot { color: var(--border); padding: 0 var(--s-1); }
  .problem {
    font-size: var(--size-body);
    color: var(--ink);
    margin: 0;
    line-height: var(--lh-body);
  }
  .see-all {
    display: inline-block;
    margin-top: var(--s-7);
    margin-left: 0;
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--s-1);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .see-all:hover,
  .see-all:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
