---
const current = Astro.url.pathname;
const items = [
  { href: '/work', label: 'Work' },
  { href: '/side-projects', label: 'Side Projects' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
];

function isActive(href: string) {
  if (href === '/') return current === '/';
  return current === href || current.startsWith(href + '/');
}
---
<header class="site-header">
  <nav class="nav container" aria-label="Primary">
    <a href="/" class="wordmark">Farrukh Jamal</a>
    <ul>
      {items.map((item) => (
        <li>
          <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: relative;
    z-index: 2;
  }
  .nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-7);
    padding-top: var(--s-6);
    padding-bottom: var(--s-6);
    font-size: var(--size-ui);
  }
  .wordmark {
    font-size: var(--size-h3);
    font-weight: 600;
    color: var(--ink);
    border-bottom: none;
    letter-spacing: -0.005em;
    transition: color 0.15s ease;
  }
  .wordmark:hover,
  .wordmark:focus-visible { color: var(--ink-bright); }
  ul { display: flex; gap: var(--s-6); margin: 0; }
  ul a {
    color: var(--muted);
    border-bottom: none;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  ul a:hover,
  ul a:focus-visible { color: var(--ink-bright); }
  ul a.active { color: var(--ink); }
  @media (max-width: 600px) {
    .nav { flex-wrap: wrap; gap: var(--s-4); }
    ul { gap: var(--s-4); }
  }
</style>
