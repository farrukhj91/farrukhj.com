<aside class="still-in-flight">
  <hr />
  <h3>Still in flight</h3>
  <div class="content"><slot /></div>
</aside>

<style>
  .still-in-flight {
    margin-top: var(--s-9);
    max-width: var(--w-text);
    font-size: var(--size-small);
    color: var(--muted);
    opacity: 0.85;
  }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: var(--s-6);
  }
  h3 {
    font-size: var(--size-meta);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--s-4);
    font-weight: 500;
  }
  .content :global(ul) { padding-left: var(--s-5); list-style: disc; }
  .content :global(li) { margin-bottom: var(--s-2); }
</style>
