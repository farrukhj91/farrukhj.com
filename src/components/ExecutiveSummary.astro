---
interface Summary { problem: string; approach: string; outcome: string; }
interface Props { summary: Summary; role: string; years: string; }
const { summary, role, years } = Astro.props as Props;
---
<section class="exec" aria-label="Executive summary">
  <p class="kicker">
    <span class="key">Role</span> {role} <span class="sep">·</span> <span class="key">Timeframe</span> {years}
  </p>
  <p class="line">{summary.problem}</p>
  <p class="line">{summary.approach}</p>
  <p class="line">{summary.outcome}</p>
</section>

<style>
  .exec {
    max-width: var(--w-text);
    margin: var(--s-7) 0 var(--s-8);
    padding: var(--s-6) var(--s-7);
    background-color: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 2px solid var(--ink-bright);
    border-radius: 2px;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--muted);
    letter-spacing: 0;
    margin: 0 0 var(--s-5);
    font-feature-settings: 'ss01', 'ss02';
    padding-bottom: var(--s-4);
    border-bottom: 1px solid var(--border);
  }
  .key {
    color: var(--ink-bright);
    font-weight: 500;
  }
  .sep { color: var(--border); padding: 0 var(--s-2); }
  .line {
    font-size: var(--size-body);
    color: var(--ink);
    line-height: var(--lh-body);
    margin: 0 0 var(--s-3);
  }
  .line:last-child { margin-bottom: 0; }
  @media (max-width: 600px) {
    .exec { padding: var(--s-5); }
  }
</style>
