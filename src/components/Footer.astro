---
const year = new Date().getFullYear();
---
<footer class="footer container">
  <div class="contact">
    <a href="mailto:farrukh.jamal91@gmail.com">farrukh.jamal91@gmail.com</a>
    <a href="https://www.linkedin.com/in/farrukh-jamal" rel="me">LinkedIn</a>
    <a href="/resume.pdf">Résumé</a>
  </div>
  <div class="copy">© {year} Farrukh Jamal</div>
</footer>

<style>
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: var(--s-7);
    padding-bottom: var(--s-7);
    margin-top: var(--s-10);
    font-size: var(--size-meta);
    color: var(--muted);
    border-top: 1px solid var(--border);
    letter-spacing: 0.01em;
  }
  .contact { display: flex; gap: var(--s-5); }
  .contact a {
    color: var(--muted);
    border-bottom: none;
    transition: color 0.15s ease;
  }
  .contact a:hover,
  .contact a:focus-visible { color: var(--ink-bright); }
  @media (max-width: 600px) {
    .footer { flex-direction: column; align-items: flex-start; gap: var(--s-3); }
  }
</style>
